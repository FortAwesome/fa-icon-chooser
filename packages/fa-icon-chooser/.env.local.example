# Local dev overrides for Font Awesome host URLs.
#
# Copy this file to `.env.local` (which is gitignored) and uncomment/edit the
# values you need. These are only loaded by the `npm start` dev server; any
# value left unset falls back to the production default baked into utils.ts.
#
# Changes are NOT hot-reloaded — stop and restart `npm start` to pick them up.

# Free CDN host (default: https://use.fontawesome.com)
#FA_FREE_CDN_URL=http://localhost:8080

# Pro kit asset host (default: https://ka-p.fontawesome.com)
#FA_PRO_KIT_ASSET_URL=http://localhost:8080

# Free kit asset host (default: https://ka-f.fontawesome.com)
#FA_FREE_KIT_ASSET_URL=http://localhost:8080
